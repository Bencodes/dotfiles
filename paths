#!/usr/bin/env bash

# Rust
export CARGO_HOME=$HOME/.cargo

# Java
JAVA_HOME="$(/usr/libexec/java_home -v 21)"
export JAVA_HOME

# Kotlin
export KOTLIN_HOME="/usr/local/opt/kotlin/"

# Configure the paths
paths=(
  /usr/local/bin
  /usr/local/sbin
  "$CARGO_HOME/bin"               # Rust
  "$JAVA_HOME/bin"                # Java
  /usr/bin                      # System
  /usr/sbin
  /sbin
  /opt/homebrew/bin             # Homebrew
  "$HOME/.bin"                    # User
)

for search_path in "${paths[@]}"; do
  [[ -d $search_path ]] \
  && [[ $PATH != *$search_path* ]] \
  && PATH=$search_path:$PATH
done

export PATH
